{
  "headers": [
    { "source": "/assets/(.*)", "headers": [{ "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }] },
    { "source": "/index.html", "headers": [{ "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }] }
  ],
  "rewrites": [
    { "source": "/live-score.html", "destination": "/live-score.html" },
    { "source": "/(.*)", "destination": "/" }
  ]
}
